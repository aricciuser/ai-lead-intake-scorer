# ════════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════════════════
#  Copy this file to .env.local and fill in your real key(s).
#  Never commit .env.local — it is already in .gitignore.
#
#  Which AI provider runs the scoring is controlled in CODE, not
#  here. To switch between OpenAI and Claude, edit the AI_PROVIDER
#  constant at the top of app/api/score-lead/route.ts.
#
#  You only need a key for whichever provider you've selected, but
#  filling in both lets you switch by changing one line.
# ════════════════════════════════════════════════════════════════

# OpenAI / ChatGPT — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic / Claude — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
