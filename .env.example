# ════════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════════════════
#  Copy this file to .env.local and fill in your real key(s).
#  Never commit .env.local — it is already in .gitignore.
# ════════════════════════════════════════════════════════════════

# Which AI provider to use. Options:
#   openai      → ChatGPT (default)
#   anthropic   → Claude
# You only need to set the API key for the provider you choose,
# but you can fill in both and switch later.
AI_PROVIDER=openai

# OpenAI / ChatGPT — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic / Claude — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
